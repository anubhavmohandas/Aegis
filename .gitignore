# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
.installed.cfg
*.egg

# --- Virtual environments ---
venv/
.venv/
env/
ENV/

# --- Packaging (PyInstaller / py2app / Nuitka) ---
build/
dist/
*.manifest
*.spec
# but keep the checked-in build recipe -- only ad-hoc generated specs are ignored
!packaging/*.spec
*.app
*.dmg
*.pkg

# --- Secrets / local env ---
.env
.env.*
*.pem
*.key
.secrets.key
secrets.enc
secrets.enc.tmp
# Glob, not the bare name: the dashboard operator credential record (salt +
# PBKDF2 hash) gets hand-copied to sidecar names like
# credentials.json.bak-admin-default during testing, and those slipped straight
# past a literal `credentials.json` entry into `git add .`.
credentials.json*

# --- Aegis runtime artifacts (regenerated on every run, not source) ---
# Tamper-evidence captures (screenshots + incident.json) -- from-source runs
# write these to the repo root via persistent_dir(); never commit them.
incidents/
aegis_events.db
events.log
*.db
*.db-journal
*.log
.aegis_monitor.json
config/config.yaml.orig

# --- Testing / coverage ---
.pytest_cache/
.coverage
htmlcov/
.hypothesis/

# --- Local tooling caches ---
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.cache/

# --- Local exports / reports ---
aegis-report-*.pdf
audit-report-*.pdf

# --- Website QA screenshots (Playwright output, regenerated on demand) ---
desktop_full.png
mobile_full.png

# --- Personal / promo images (not part of the product) ---
LinkedIN.png
LinkedIn.png
linkedin.png

# --- IDE ---
.vscode/
.idea/
*.swp

# --- OS cruft ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini
